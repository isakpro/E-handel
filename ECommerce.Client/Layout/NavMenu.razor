@implements IDisposable

<nav class="navbar navbar-expand-lg navbar-dark sport-navbar">
    <div class="container">
        <NavLink class="navbar-brand fw-bold" href="">
            <i class="bi bi-shop me-2" style="color:#e8002d"></i>SportGear
        </NavLink>

        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu" aria-controls="navbarNav"
                aria-expanded="@(!collapseNavMenu)" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse @NavMenuCssClass" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-house me-1"></i>Hem
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="products">
                        <i class="bi bi-grid me-1"></i>Produkter
                    </NavLink>
                </li>
            </ul>

            <ul class="navbar-nav">
                <li class="nav-item">
                    <NavLink class="nav-link position-relative" href="cart">
                        <i class="bi bi-cart3 fs-4 text-danger"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            @cartItemCount
                            <span class="visually-hidden">items in cart</span>
                        </span>
                    </NavLink>
                </li>

                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                               aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>Mina Sidor
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <NavLink class="dropdown-item" href="orders">
                                        <i class="bi bi-receipt me-2"></i>Mina Ordrar
                                    </NavLink>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" style="cursor: pointer;" @onclick="HandleLogout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logga ut
                                    </a>
                                </li>
                            </ul>
                        </li>

                        @* Backoffice - bara för Admin *@
                        <AuthorizeView Roles="Admin">
                            <Authorized Context="adminContext">
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle fw-bold" href="#" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-gear me-1"></i>Backoffice
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <NavLink class="dropdown-item" href="admin/orders">
                                                <i class="bi bi-receipt me-2"></i>Hantera Ordrar
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink class="dropdown-item" href="admin/products">
                                                <i class="bi bi-list-nested me-2"></i>Hantera Produkter
                                            </NavLink>
                                        </li>
                                    </ul>
                                </li>
                            </Authorized>
                        </AuthorizeView>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="login">
                                <i class="bi bi-person me-1"></i>Logga in
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@code {
    // Styr om mobilmenyn är öppen eller stängd
    private bool collapseNavMenu = true;

    // Lägger till Bootstrap-klassen "show" när menyn är öppen på mobil
    private string? NavMenuCssClass => collapseNavMenu ? "" : "show";

    // Hämtar alltid aktuellt antal varor direkt från CartService (computed property)
    private int cartItemCount => CartService.GetItemCount();

    // Injicerade tjänster via Dependency Injection
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] NavigationManager NavManager { get; set; } = default!;
    [Inject] IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] CartService CartService { get; set; } = default!;

    // Prenumererar på CartService.OnChange när komponenten startar.
    // Varje gång varukorgen ändras körs StateHasChanged() → badgen uppdateras.
    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged;
    }

    // Avprenumererar när komponenten tas bort för att undvika minnesläckor
    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }

    // Växlar mobilmenyns synlighet
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    // Loggar ut användaren och skickar tillbaka till startsidan
    private async Task HandleLogout()
    {
        var customProvider = (CustomAuthStateProvider)AuthStateProvider;
        await customProvider.MarkUserAsLoggedOut();
        NavManager.NavigateTo("/");
    }
}