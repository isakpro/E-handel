@using ECommerce.Shared.DTOs
@using ECommerce.Client.Services
@inject CartService CartService
@inject NavigationManager Nav

<div class="product-card" @onclick="GoToDetail">
    <div class="product-image-placeholder">
        <i class="bi bi-image fs-1"></i>
    </div>
    <div class="product-card-body">
        <h5 class="product-title">@Product.Name</h5>
        <p class="product-description">@Product.Description</p>
        <div class="product-price-row">
            <span class="product-price">@Product.Price kr</span>
        </div>
    </div>
    <div class="product-card-footer">
        <button class="btn btn-add-cart" @onclick="AddToCart" @onclick:stopPropagation="true">
            <i class="bi bi-cart-plus"></i> Lägg i varukorg
        </button>
    </div>
</div>

@code {
    [Parameter]
    public ProductDto Product { get; set; } = default!;

    private void AddToCart() => CartService.AddToCart(Product);

    private void GoToDetail() => Nav.NavigateTo($"/products/{Product.Id}");
}