@using ECommerce.Shared.DTOs
@using ECommerce.Client.Services
@inject ICartService CartService
@inject NavigationManager Nav

<div class="card h-100 shadow-sm product-card" style="cursor:pointer" @onclick="GoToDetail">
    <div class="img-container">
        <img src="@Product.ImageUrl" class="card-img-top product-img" alt="@Product.Name"
             onerror="this.src='https://placehold.co/400x200?text=Ingen+bild'" />
    </div>
    <div class="card-body text-center">
        <h5 class="card-title">@Product.Name</h5>
        <p class="card-text text-muted">@Product.Description</p>
        <h4 class="text-primary">@Product.Price kr</h4>
    </div>
    <div class="card-footer bg-white border-top-0 text-center">
        <button class="btn btn-outline-success w-100" @onclick="AddToCart" @onclick:stopPropagation="true">
            <i class="bi bi-cart-plus"></i> Lägg i varukorg
        </button>
    </div>
</div>

<style>
    .img-container {
        overflow: hidden;
        height: 220px;
        transition: height 0.3s ease;
        background-color: white;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .product-card:hover .img-container {
        height: 400px;
    }

    .product-card:hover .product-img {
        transform: scale(1.05);
    }
</style>

@code {
    [Parameter]
    public ProductDto Product { get; set; } = default!;

    private void AddToCart() => CartService.AddToCart(Product);

    private void GoToDetail() => Nav.NavigateTo($"/products/{Product.Id}");
}