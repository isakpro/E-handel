@page "/products"
@using ECommerce.Shared.DTOs
@using ECommerce.Client.Components
@inject HttpClient Http

<h3>Vårt Sortiment</h3>

<div class="mb-3">
    <input class="form-control" type="text" placeholder="Sök produkt..." @bind="searchText" @bind:event="oninput" />
</div>

<EditForm Model="@filterModel" OnValidSubmit="ApplyFilter">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <InputNumber class="form-control" @bind-Value="filterModel.MinPrice" placeholder="Min pris (kr)" />
            <ValidationMessage For="@(() => filterModel.MinPrice)" />
        </div>
        <div class="col-md-3">
            <InputNumber class="form-control" @bind-Value="filterModel.MaxPrice" placeholder="Max pris (kr)" />
            <ValidationMessage For="@(() => filterModel.MaxPrice)" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filtrera</button>
        </div>
    </div>
</EditForm>

@if (errorMessage != null)
{
    <div class="alert alert-danger">
        <strong>Något gick fel!</strong> @errorMessage
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadProducts">Försök igen</button>
    </div>
}
else if (products == null)
{
    <p><em>Laddar produkter...</em></p>
}
else if (!filteredProducts.Any())
{
    <p>Inga produkter hittades.</p>
}
else
{
    <div class="row g-4">
        @foreach (var product in filteredProducts)
        {
            <div class="col-md-4 col-sm-6">
                <ProductCard Product="product" />
            </div>
        }
    </div>
}

@code {
    private ProductDto[]? products;
    private string searchText = "";
    private string? errorMessage;
    private PriceFilterModel filterModel = new();
    private decimal activeMinPrice = 0;
    private decimal activeMaxPrice = decimal.MaxValue;

    private IEnumerable<ProductDto> filteredProducts =>
        products?.Where(p =>
            (p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
             p.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            p.Price >= activeMinPrice &&
            p.Price <= activeMaxPrice)
        ?? Enumerable.Empty<ProductDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        try
        {
            errorMessage = null;
            products = null;
            products = await Http.GetFromJsonAsync<ProductDto[]>("api/products");
        }
        catch (Exception)
        {
            errorMessage = "Kunde inte hämta produkter. Kontrollera att API:et körs.";
        }
    }

    private void ApplyFilter()
    {
        activeMinPrice = filterModel.MinPrice ?? 0;
        activeMaxPrice = filterModel.MaxPrice ?? decimal.MaxValue;
    }

    public class PriceFilterModel
    {
        [System.ComponentModel.DataAnnotations.Range(0, 100000,
            ErrorMessage = "Min pris måste vara mellan 0 och 100 000 kr")]
        public decimal? MinPrice { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0, 100000,
            ErrorMessage = "Max pris måste vara mellan 0 och 100 000 kr")]
        public decimal? MaxPrice { get; set; }
    }
}