@page "/"
@using ECommerce.Shared.DTOs
@using ECommerce.Client.Components
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Hem - E-handel</PageTitle>

<!-- Hero Section -->
<section class="hero-banner bg-primary text-white">
  <div class="container">
    <div class="row align-items-center min-vh-50">
      <div class="col-lg-6">
        <div class="hero-content">
          <h1 class="display-4 fw-bold mb-4">
            Välkommen till E-handel
          </h1>
          <p class="lead mb-4">
            Upptäck vårt fantastiska sortiment av kvalitetsprodukter.
            Snabb leverans, bra priser och utmärkt kundservice.
          </p>
          <div class="d-flex gap-3">
            <button class="btn btn-light btn-lg px-4" @onclick="NavigateToProducts">
              <i class="bi bi-shop me-2"></i>Shoppa nu
            </button>
            <button class="btn btn-outline-light btn-lg px-4" @onclick="ScrollToFeatured">
              <i class="bi bi-arrow-down me-2"></i>Se populära produkter
            </button>
          </div>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <div class="hero-image">
          <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&h=400&fit=crop&crop=center"
               alt="Shopping"                class="img-fluid rounded shadow-lg"       style="max-height: 400px; object-fit: cover;" />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="features-section py-5 bg-light">
  <div class="container">
    <div class="row text-center">
      <div class="col-md-4 mb-4">
        <div class="feature-card h-100">
          <div class="feature-icon text-primary mb-3">
            <i class="bi bi-truck fs-1"></i>
          </div>
          <h5 class="fw-bold">Snabb leverans</h5>
          <p class="text-muted">Fri frakt på beställningar över 500 kr</p>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="feature-card h-100">
          <div class="feature-icon text-primary mb-3">
            <i class="bi bi-shield-check fs-1"></i>
          </div>
          <h5 class="fw-bold">Säker betalning</h5>
          <p class="text-muted">100% säkra betalningar med SSL-kryptering</p>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="feature-card h-100">
          <div class="feature-icon text-primary mb-3">
            <i class="bi bi-headset fs-1"></i>
          </div>
          <h5 class="fw-bold">24/7 Support</h5>
          <p class="text-muted">Vårt supportteam finns alltid här för dig</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Featured Products Section -->
<section id="featured-products" class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold">Populära Produkter</h2>
      <p class="lead text-muted">Upptäck våra mest älskade produkter</p>
    </div>

    @if (featuredProducts == null)
    {
      <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Laddar produkter...</span>
        </div>
      </div>
    }
    else if (!featuredProducts.Any())
    {
      <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-2"></i>
        Inga populära produkter att visa för tillfället.
      </div>
    }
    else
    {
      <div class="row g-4">
        @foreach (var product in featuredProducts.Take(4))
        {
          <div class="col-lg-3 col-md-6">
            <ProductCard Product="product" />
          </div>
        }
      </div>

      <div class="text-center mt-4">
        <a href="/products" class="btn btn-primary btn-lg">
          <i class="bi bi-grid me-2"></i>Se alla produkter
        </a>
      </div>
    }
  </div>
</section>

@code {
  private List<ProductDto>? featuredProducts;

  protected override async Task OnInitializedAsync()
  {
    await LoadFeaturedProducts();
  }

  private async Task LoadFeaturedProducts()
  {
    try
    {
      var response = await Http.GetAsync("api/products");
      if (response.IsSuccessStatusCode)
      {
        var allProducts = await response.Content.ReadFromJsonAsync<List<ProductDto>>();
        // Take first 4 products as featured - could be enhanced with actual featured flag
        featuredProducts = allProducts?.Take(4).ToList() ?? new List<ProductDto>();
      }
      else
      {
        featuredProducts = new List<ProductDto>();
      }
    }
    catch (Exception)
    {
      // Fallback to empty list on error
      featuredProducts = new List<ProductDto>();
    }
  }

  private void NavigateToProducts()
  {
    NavManager.NavigateTo("/products");
  }

  private async Task ScrollToFeatured()
  {
    // Simple navigation to products for now - could be enhanced with JS scrolling to featured section
    NavManager.NavigateTo("/products");
  }
}