@page "/login"
@using ECommerce.Shared.DTOs
@using ECommerce.Client.Services
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<PageTitle>Logga in</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">Välkommen tillbaka</h3>

                    <EditForm Model="loginRequest" OnValidSubmit="HandleLogin">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label text-muted">E-postadress</label>
                            <InputText @bind-Value="loginRequest.Email" class="form-control" placeholder="namn@exempel.se" />
                            <ValidationMessage For="@(() => loginRequest.Email)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted">Lösenord</label>
                            <InputText @bind-Value="loginRequest.Password" type="password" class="form-control" placeholder="******" />
                            <ValidationMessage For="@(() => loginRequest.Password)" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 mt-3 shadow-sm">
                            Logga in
                        </button>
                    </EditForm>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3 mb-0 text-center">@errorMessage</div>
                    }

                    <div class="text-center mt-4 border-top pt-3">
                        <span class="small text-muted">Har du inget konto?</span>
                        <a href="/register" class="text-decoration-none ms-1">Skapa ett konto</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginRequest = new();
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        try
        {
            errorMessage = "";
            var response = await Http.PostAsJsonAsync("api/auth/login", loginRequest);
            if (response.IsSuccessStatusCode)
            {
                var authResult = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (authResult != null && !string.IsNullOrEmpty(authResult.Token))
                {
                    await ((CustomAuthStateProvider)AuthStateProvider).MarkUserAsAuthenticated(authResult.Token);
                    NavManager.NavigateTo("/");
                }
            }
            else
            {
                errorMessage = "Felaktig e-post eller lösenord.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Kunde inte ansluta till servern.";
        }
    }
}