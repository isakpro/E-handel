@page "/cart"
@using ECommerce.Client.Services
@using ECommerce.Client.Components
@using ECommerce.Shared.DTOs
@inject ICartService CartService
@inject HttpClient Http
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<h3>Din Kundvagn</h3>

@if (!CartService.GetCartItems().Any())
{
    <p>Din kundvagn är tom.</p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Produkt</th><th>Pris</th><th>Antal</th><th>Totalt</th></tr>
        </thead>
        <tbody>
            @foreach (var item in CartService.GetCartItems())
            {
                <CartItemRow Item="item" />
            }
        </tbody>
    </table>
    
    <h4 class="text-center">Totalsumma: @CartService.GetTotal() kr</h4>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <AuthorizeView>
        <Authorized>
            <div class="text-end mt-3">
                <button class="btn btn-success btn-lg" @onclick="Checkout">Slutför köp</button>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning text-end mt-3">
                Du måste <a href="/login">logga in</a> för att slutföra köpet.
            </div>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    private string successMessage = string.Empty;

    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged; // Lyssna på ändringar i vagnen
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged; // Undvik minnesläckor
    }

    private async Task Checkout()
    {
        var orderDto = new OrderDto
        {
            Items = CartService.GetCartItems().ToList(),
            TotalAmount = CartService.GetTotal(),
            OrderDate = DateTime.Now
        };

        // Hämta JWT-token och lägg till den i anropet till API:et
        var customProvider = (CustomAuthStateProvider)AuthStateProvider;
        var token = await customProvider.GetTokenAsync();

        var request = new HttpRequestMessage(HttpMethod.Post, "api/orders");
        request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        request.Content = JsonContent.Create(orderDto);

        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            successMessage = "Tack för din beställning din arab";
            StateHasChanged();
        }
    }
}